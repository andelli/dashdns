{
  "name": "dashdns-backend",
  "version": "1.0.0",
  "description": "DNS monitoring dashboard for dnsdist and PowerDNS resolver",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "setup": "npm run migrate && npm run seed",
    "build-frontend": "cd ../frontend && npm run build"
  },
  "keywords": [
    "dns",
    "monitoring",
    "dashboard",
    "dnsdist",
    "powerdns"
  ],
