[Unit]
Description=DashDNS - DNS Monitoring Dashboard
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/dashdns/backend
ExecStart=/usr/bin/node /opt/dashdns/backend/server.js
Restart=always
RestartSec=10
StandardOutput=append:/var/log/dashdns.log
StandardError=append:/var/log/dashdns-error.log
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
